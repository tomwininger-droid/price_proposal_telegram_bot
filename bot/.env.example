# העתק קובץ זה ל-.env ומלא את הערכים האמיתיים. אל תעלה את .env ל-git.

# ===== חובה — בלי אלה הבוט לא עולה =====

# טוקן הבוט מ-@BotFather בטלגרם
TELEGRAM_BOT_TOKEN=123456:ABC-your-telegram-bot-token

# מפתח OpenAI (לתמלול Whisper + הקראה TTS)
OPENAI_API_KEY=sk-...

# מפתח Anthropic (ליצירת ההצעה עם Claude)
ANTHROPIC_API_KEY=sk-ant-...

# מזהי המשתמשים בטלגרם שמורשים להשתמש בבוט (מופרדים בפסיקים).
# כדי לגלות את ה-id שלך: שלח הודעה לבוט @userinfobot בטלגרם.
# חשוב: השארת שדה זה ריק = כל אחד שמוצא את הבוט יכול להשתמש בו ולבזבז את קרדיט ה-API שלך.
ALLOWED_USER_IDS=

# הכתובת הציבורית שבה הכלי מוגש. הלינקים שהבוט שולח ייבנו על בסיסה.
# פריסה עצמאית (VPS): http://<IP>:8080 או https://<דומיין>
# פריסה ב-Render: זו כתובת השירות שמוצגת בדשבורד שלו, למשל https://my-quote-bot.onrender.com
PUBLIC_BASE_URL=http://localhost:8080

# ===== הגדרות בסיס (יש ברירת מחדל תקינה, אפשר לא לגעת) =====

PORT=8080
CLAUDE_MODEL=claude-sonnet-4-6

# מכסת הצעות חודשית למשתמש (אכיפת חבילה + הגנה על עלות AI).
# רגיל=15, פלוס=50, סופר=150. 0 או ריק = ללא הגבלה.
MONTHLY_QUOTE_LIMIT=0

# ===== מיתוג — שם העסק שמופיע בכלי, בהודעות הבוט, ובמיילים =====

BUSINESS_NAME=Brands Or Not
BUSINESS_SLOGAN=עיצוב. חוויית משתמש. דיגיטל
# שם פרטי לחתימת המייל (אופציונלי). אם ריק, החתימה תהיה רק שם העסק.
SENDER_NAME=
# צבעים בפורמט hex. PRIMARY_COLOR = הצבע הראשי (כותרות/לוגו), BG_COLOR = רקע בהיר.
PRIMARY_COLOR=#3B2BCB
BG_COLOR=#F4F3FA

# ===== אופציונלי: שליחת מייל ללקוח (Google Workspace / Gmail) =====
# בלי אלה — כפתור "שלח ללקוח במייל" פשוט לא יופיע, הבוט ימשיך לעבוד.
# SMTP_PASS הוא App Password — לא הסיסמה הרגילה לחשבון Google.
# להפקה: myaccount.google.com/apppasswords (דורש אימות דו-שלבי מופעל בחשבון).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# ===== אופציונלי: העלאת כל ההצעות (PDF) לתיקיית Google Drive משותפת =====
# בלי אלה — הבוט פשוט לא מעלה לדרייב, שום דבר אחר לא משתנה.
# דורש Service Account (לא חשבון Gmail רגיל) — ראה SETUP_GUIDE.md לשלבי ההקמה.
DRIVE_FOLDER_ID=
# שתי דרכים למפתח ה-Service Account — מלאו רק אחת:
# (א) קובץ JSON על הדיסק, נתיב יחסי לתיקיית bot/ (מתאים לפריסה עצמאית/VPS):
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=drive-service-account.json
# (ב) כל קובץ ה-JSON מקודד ב-base64 כשורה אחת (מתאים לטופס פריסה כמו Render):
#     base64 -i key.json | pbcopy   (Mac)   /   certutil -encode key.json key.b64   (Windows)
GOOGLE_SERVICE_ACCOUNT_KEY_B64=

# ===== אופציונלי: מיקום קבצי הנתונים (להצעות + מצב שיחה) =====
# בפריסה עצמאית (VPS) — להשאיר ריק, ההתנהגות הקיימת נשארת בדיוק כמו שהיא.
# בפריסה ב-Render — מצביע לתיקיית הדיסק הקבוע שמחובר לשירות, כדי שהצעות ושיחות
# ישרדו ריסטארט/דיפלוי חדש. לדוגמה: /app/data
DATA_DIR=

# ===== אופציונלי: טוקן לדף בדיקת התקינות (/quote-tool/setup-status?token=...) =====
# אם ריק, נגזר טוקן יציב מתוך TELEGRAM_BOT_TOKEN — לא צריך למלא בעצמך.
SETUP_STATUS_TOKEN=
